# Meta App configuration
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_GRAPH_API_VERSION=v25.0

# Short-lived User Token from Graph API Explorer → run scripts/refresh_all_tokens.py
# After refresh this holds the long-lived user token (~60 days)
META_USER_ACCESS_TOKEN=replace_with_long_lived_user_token

# Target Facebook Page and linked Instagram Business account
META_PAGE_ID=your_facebook_page_id
META_PAGE_ACCESS_TOKEN=replace_with_page_access_token
META_INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# Application settings
APP_ENV=development
APP_DEBUG=true
DATABASE_PATH=data/social_search.db
SYNC_PAGE_SIZE=100
REQUEST_TIMEOUT_SECONDS=30
